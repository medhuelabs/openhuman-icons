{
  "$id": "https://icons.openhumanatlas.com/icon.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenHuman Icons metadata schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "contributors", "categories", "tags", "use-cases"],
  "properties": {
    "$schema": { "type": "string" },
    "aliases": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "deprecated": { "const": true },
          "deprecationReason": { "type": "string" },
          "toBeRemovedInVersion": {
            "type": "string",
            "pattern": "^v[0-9]+(?:\\.[0-9]+)+$"
          }
        },
        "dependentRequired": {
          "deprecated": ["deprecationReason", "toBeRemovedInVersion"],
          "deprecationReason": ["deprecated"],
          "toBeRemovedInVersion": ["deprecated"]
        }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "anatomy",
          "diagnostics",
          "devices",
          "medications",
          "procedures",
          "specialties",
          "wellness"
        ]
      }
    },
    "contributors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "use-cases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "deprecated": { "const": true },
    "deprecationReason": { "type": "string" },
    "toBeRemovedInVersion": {
      "type": "string",
      "pattern": "^v[0-9]+(?:\\.[0-9]+)+$"
    }
  },
  "dependentRequired": {
    "deprecated": ["deprecationReason", "toBeRemovedInVersion"],
    "deprecationReason": ["deprecated"],
    "toBeRemovedInVersion": ["deprecated"]
  }
}
