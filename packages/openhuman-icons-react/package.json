{
  "name": "@medhuelabs/openhuman-icons-react",
  "version": "0.1.0",
  "description": "React components for OpenHuman medical SVG icons.",
  "license": "ISC",
  "homepage": "https://icons.openhumanatlas.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/medhuelabs/openhuman-icons.git",
    "directory": "packages/openhuman-icons-react"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js",
      "require": "./dist/icons/*.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "test": "vitest run ../../tests/react-package.test.tsx"
  },
  "dependencies": {
    "@medhuelabs/openhuman-icons": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.0"
  },
  "peerDependencies": {
    "react": "^16.5.1 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  }
}
